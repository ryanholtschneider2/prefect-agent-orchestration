{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "po Helm chart values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride":     { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonLabels":      { "type": "object" },
    "commonAnnotations": { "type": "object" },

    "pool": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name":             { "type": "string", "minLength": 1 },
        "type":             { "type": "string", "enum": ["process", "kubernetes", "docker"] },
        "concurrencyLimit": { "type": ["integer", "null"], "minimum": 0 }
      }
    },

    "worker": {
      "type": "object",
      "required": ["replicaCount", "image"],
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag":        { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "imagePullSecrets": { "type": "array", "items": { "type": "object" } },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create":      { "type": "boolean" },
            "name":        { "type": "string" },
            "annotations": { "type": "object" }
          }
        },
        "backend": { "type": "string", "enum": ["cli", "tmux", "stub"] },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled":                        { "type": "boolean" },
            "minReplicas":                    { "type": "integer", "minimum": 1 },
            "maxReplicas":                    { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        }
      }
    },

    "prefectServer": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag":        { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled":      { "type": "boolean" },
            "accessMode":   { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
            "size":         { "type": "string" },
            "storageClass": { "type": "string" }
          }
        }
      }
    },

    "ingress": {
      "type": "object",
      "properties": {
        "enabled":     { "type": "boolean" },
        "className":   { "type": "string" },
        "annotations": { "type": "object" },
        "hosts":       { "type": "array",  "items": { "type": "object" } },
        "tls":         { "type": "array",  "items": { "type": "object" } }
      }
    },

    "rig": {
      "type": "object",
      "properties": {
        "create":        { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "accessMode":    { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
        "size":          { "type": "string" },
        "storageClass":  { "type": "string" },
        "mountPath":     { "type": "string", "pattern": "^/" }
      }
    },

    "auth": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["apikey", "oauth"] },
        "apikey": {
          "type": "object",
          "properties": {
            "secretName":   { "type": "string", "minLength": 1 },
            "secretKey":    { "type": "string", "minLength": 1 },
            "createSecret": { "type": "boolean" },
            "apiKey":       { "type": "string" },
            "pool": {
              "type": "object",
              "properties": {
                "enabled":      { "type": "boolean" },
                "size":         { "type": "integer", "minimum": 0 },
                "secretName":   { "type": "string", "minLength": 1 },
                "secretKey":    { "type": "string", "minLength": 1 },
                "createSecret": { "type": "boolean" },
                "apiKeys":      { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "oauth": {
          "type": "object",
          "properties": {
            "secretName":      { "type": "string", "minLength": 1 },
            "secretKey":       { "type": "string", "minLength": 1 },
            "createSecret":    { "type": "boolean" },
            "credentialsJson": { "type": "string" },
            "persistence": {
              "type": "object",
              "properties": {
                "enabled":      { "type": "boolean" },
                "accessMode":   { "type": "string" },
                "size":         { "type": "string" },
                "storageClass": { "type": "string" }
              }
            },
            "pool": {
              "type": "object",
              "properties": {
                "enabled":      { "type": "boolean" },
                "size":         { "type": "integer", "minimum": 0 },
                "secretName":   { "type": "string", "minLength": 1 },
                "secretKey":    { "type": "string", "minLength": 1 },
                "createSecret": { "type": "boolean" },
                "credentials":  { "type": "array", "items": { "type": "object" } }
              }
            }
          }
        }
      }
    },

    "claudeContextOverrides": {
      "type": "object",
      "properties": {
        "name":   { "type": "string", "minLength": 1 },
        "create": { "type": "boolean" },
        "data":   { "type": "object" }
      }
    },

    "poolRegister": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag":        { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "backoffLimit":            { "type": "integer", "minimum": 0 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
