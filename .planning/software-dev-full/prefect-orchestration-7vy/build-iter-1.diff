+"""Shared fixtures for retro pack tests.
+
+Builds a fake target-pack git repo and a rig with three matching
+lesson runs. Tests can then point the flow at these via fixture
+fixtures rather than touching importlib metadata.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import subprocess
+from pathlib import Path
+
+import pytest
+
+
+def _git(repo: Path, *args: str) -> str:
+    out = subprocess.run(
+        ["git", *args],
+        cwd=str(repo),
+        check=True,
+        text=True,
+        capture_output=True,
+    )
+    return out.stdout.strip()
+
+
+@pytest.fixture
+def fake_target_repo(tmp_path: Path) -> Path:
+    """A git repo with a po-formula-shaped pyproject + a fake prompt file."""
+    repo = tmp_path / "fake-pack-repo"
+    pkg = repo / "po_formulas_fake"
+    (pkg / "agents" / "builder").mkdir(parents=True)
+    (pkg / "agents" / "builder" / "prompt.md").write_text(
+        "You are the builder.\n"
+    )
+    (repo / "pyproject.toml").write_text(
+        '[project]\nname = "po-formulas-fake"\n\n'
+        '[project.entry-points."po.formulas"]\n'
+        'fake-formula = "po_formulas_fake:run"\n'
+    )
+    _git(repo, "init", "-q", "-b", "main")
+    _git(repo, "config", "user.email", "test@example.com")
+    _git(repo, "config", "user.name", "Test")
+    _git(repo, "add", "-A")
+    _git(repo, "-c", "core.hooksPath=/dev/null", "commit", "-q", "-m", "init")
+    return repo
+
+
+@pytest.fixture
+def fake_rig_with_runs(tmp_path: Path) -> Path:
+    """Rig with three run dirs of formula 'fake-formula', each with the same lesson."""
+    rig = tmp_path / "fake-rig"
+    formula_dir = rig / ".planning" / "fake-formula"
+    for issue_id in ("issue-1", "issue-2", "issue-3"):
+        rd = formula_dir / issue_id
+        rd.mkdir(parents=True)
+        (rd / "lessons-learned.md").write_text(
+            "Always run `bd prime` after a session reset.\n"
+        )
+        (rd / "decision-log.md").write_text(
+            "- Decision: used scoped git add to avoid sweeping other workers' work.\n"
+        )
+    return rig
+
+
+@pytest.fixture
+def stub_synthesis_payload() -> dict:
+    """A canned synthesizer verdict that targets a prompt file edit."""
+    return {
+        "recurring": [
+            {
+                "theme": "Run `bd prime` after session reset",
+                "evidence": ["issue-1", "issue-2", "issue-3"],
+                "target_file": "po_formulas_fake/agents/builder/prompt.md",
+                "edit": {
+                    "append": "\n\n## Reminder\nRun `bd prime` after a session reset.\n"
+                },
+            }
+        ],
+        "single_occurrence": [
+            {"note": "scoped git add avoids worker collisions", "target_pack": "po-formulas-fake"}
+        ],
+    }
