@@ -0,0 +1,384 @@
+"""Prefect flow: `update_prompts_from_lessons`.
+
+Walks recent `lessons-learned.md` + `decision-log.md` artifacts from
+the target pack's run dirs, synthesizes recurring patterns via one
+Claude turn, and commits proposed prompt / skill / CLAUDE.md edits to
+the target pack's repo. Single-occurrence lessons land in
+`bd remember` instead of file edits.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import shutil
+import subprocess
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+from prefect import flow, get_run_logger, task
+
+from prefect_orchestration.agent_session import (
+    AgentSession,
+    ClaudeCliBackend,
+    StubBackend,
+    TmuxClaudeBackend,
+)
+from prefect_orchestration.parsing import read_verdict, verdicts_dir
+from prefect_orchestration.templates import render_template
+
+from . import analysis, git_ops
+
+_AGENTS_DIR = Path(__file__).parent / "agents"
+_FORMULA_NAME = "update-prompts-from-lessons"
+_RUN_DIR_FORMULA = "update-prompts-from-lessons"
+
+
+def _render(role: str, **vars: object) -> str:
+    return render_template(_AGENTS_DIR, role, **vars)
+
+
+def _utc_timestamp() -> str:
+    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
+
+
+def _select_backend() -> Any:
+    """Mirror software_dev's PO_BACKEND switch."""
+    forced = os.environ.get("PO_BACKEND", "").strip().lower()
+    if forced == "stub":
+        return StubBackend()
+    if forced == "tmux":
+        if not shutil.which("tmux"):
+            raise RuntimeError("PO_BACKEND=tmux but tmux is not on PATH")
+        return TmuxClaudeBackend(issue="retro", role="synthesizer")
+    if forced == "cli":
+        return ClaudeCliBackend()
+    # Default: tmux when available, else cli.
+    if shutil.which("tmux"):
+        return TmuxClaudeBackend(issue="retro", role="synthesizer")
+    return ClaudeCliBackend()
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Tasks
+# ──────────────────────────────────────────────────────────────────────
+
+
+@task(name="locate_target_pack", tags=["retro"])
+def locate_target_pack(target_pack: str) -> dict[str, Any]:
+    logger = get_run_logger()
+    try:
+        repo_root = analysis.pack_repo_root(target_pack)
+    except LookupError as exc:
+        logger.warning(f"refused to operate on {target_pack}: {exc}")
+        return {"refused": str(exc)}
+    formulas = analysis.pack_formula_names(repo_root)
+    logger.info(f"target pack {target_pack} -> {repo_root} (formulas={formulas})")
+    return {"repo_root": str(repo_root), "formulas": formulas}
+
+
+@task(name="collect_lessons", tags=["retro"])
+def collect_lessons(
+    rig_path: str, formulas: list[str], since: str
+) -> list[dict[str, Any]]:
+    logger = get_run_logger()
+    delta = analysis.parse_since(since)
+    runs: list[dict[str, Any]] = []
+    for run_dir in analysis.iter_run_dirs(Path(rig_path), formulas, delta):
+        body = analysis.read_lessons_and_decisions(run_dir)
+        if not body:
+            continue
+        runs.append(
+            {
+                "run_id": run_dir.name,
+                "formula": run_dir.parent.name,
+                "lessons": body.get("lessons", ""),
+                "decisions": body.get("decisions", ""),
+            }
+        )
+    logger.info(f"collected {len(runs)} runs with lessons/decisions since {since}")
+    return runs
+
+
+def _format_lessons_blob(runs: list[dict[str, Any]]) -> str:
+    parts: list[str] = []
+    for r in runs:
+        chunks: list[str] = []
+        if r.get("lessons"):
+            chunks.append(f"## lessons-learned.md\n\n{r['lessons']}")
+        if r.get("decisions"):
+            chunks.append(f"## decision-log.md\n\n{r['decisions']}")
+        body = "\n\n".join(chunks)
+        parts.append(f'<run id="{r["run_id"]}" formula="{r["formula"]}">\n{body}\n</run>')
+    return "\n\n".join(parts) if parts else "(no recent runs)"
+
+
+@task(name="synthesize", tags=["synthesizer"])
+def synthesize(
+    target_pack: str,
+    target_repo_root: str,
+    runs: list[dict[str, Any]],
+    run_dir: str,
+) -> dict[str, Any]:
+    logger = get_run_logger()
+    if not runs:
+        logger.info("no runs collected; producing empty synthesis")
+        return {"recurring": [], "single_occurrence": []}
+
+    run_dir_p = Path(run_dir)
+    verdict_path = verdicts_dir(run_dir_p) / "synthesize.json"
+
+    sess = AgentSession(
+        role="synthesizer",
+        repo_path=Path(target_repo_root),
+        backend=_select_backend(),
+        skip_mail_inject=True,
+    )
+    prompt = _render(
+        "synthesizer",
+        target_pack=target_pack,
+        target_repo_root=target_repo_root,
+        n_runs=len(runs),
+        run_dir=str(run_dir_p),
+        verdict_path=str(verdict_path),
+        lessons_blob=_format_lessons_blob(runs),
+    )
+    sess.prompt(prompt)
+    payload = read_verdict(run_dir_p, "synthesize")
+    recurring_in = payload.get("recurring") or []
+    singles_in = payload.get("single_occurrence") or []
+    recurring = analysis.filter_recurring(
+        [r for r in recurring_in if isinstance(r, dict)]
+    )
+    singles = [s for s in singles_in if isinstance(s, dict) and s.get("note")]
+    logger.info(
+        f"synthesized: {len(recurring)} recurring (after filter), "
+        f"{len(singles)} single-occurrence"
+    )
+    return {"recurring": recurring, "single_occurrence": singles}
+
+
+def _apply_edit(target_path: Path, edit: Any) -> None:
+    """Apply one edit. `edit` is either a string (full rewrite) or
+    {"append": str} (append to existing or create)."""
+    target_path.parent.mkdir(parents=True, exist_ok=True)
+    if isinstance(edit, str):
+        target_path.write_text(edit)
+        return
+    if isinstance(edit, dict) and "append" in edit:
+        suffix = str(edit["append"])
+        existing = target_path.read_text() if target_path.exists() else ""
+        if existing and not existing.endswith("\n"):
+            existing += "\n"
+        target_path.write_text(existing + suffix)
+        return
+    raise ValueError(f"unrecognized edit shape: {edit!r}")
+
+
+@task(name="apply_changes_and_commit", tags=["retro"])
+def apply_changes_and_commit(
+    repo_root: str,
+    target_pack: str,
+    recurring: list[dict[str, Any]],
+    n_runs: int,
+    since: str,
+    timestamp: str,
+    dry_run: bool,
+) -> dict[str, Any]:
+    logger = get_run_logger()
+    if dry_run or not recurring:
+        return {
+            "branch": None,
+            "commit_sha": None,
+            "edited_files": [],
+            "skipped_reason": "dry-run" if dry_run else "no recurring patterns",
+        }
+
+    repo = Path(repo_root)
+    edited_paths: list[Path] = []
+    for item in recurring:
+        rel = item["target_file"]
+        # Defense-in-depth: re-validate the path here as well.
+        if not analysis.is_allowed_target_path(rel):
+            logger.warning(f"dropping disallowed path: {rel}")
+            continue
+        target = (repo / rel).resolve()
+        try:
+            target.relative_to(repo.resolve())
+        except ValueError:
+            logger.warning(f"dropping path outside repo: {rel}")
+            continue
+        _apply_edit(target, item.get("edit"))
+        edited_paths.append(target)
+
+    if not edited_paths:
+        return {
+            "branch": None,
+            "commit_sha": None,
+            "edited_files": [],
+            "skipped_reason": "all edits filtered",
+        }
+
+    branch_created = git_ops.ensure_retro_branch(repo, timestamp)
+    branch_name = branch_created or git_ops.current_branch(repo)
+    message = (
+        f"retro({target_pack}): integrate lessons from {n_runs} runs since {since}"
+    )
+    sha = git_ops.commit_paths(repo, edited_paths, message)
+    return {
+        "branch": branch_name,
+        "branch_created": branch_created is not None,
+        "commit_sha": sha,
+        "edited_files": [str(p.relative_to(repo)) for p in edited_paths],
+    }
+
+
+def _bd_remember(text: str) -> bool:
+    """Best-effort `bd remember` shell-out; returns True on rc=0."""
+    if not shutil.which("bd"):
+        return False
+    rc = subprocess.run(
+        ["bd", "remember", text], capture_output=True, text=True
+    ).returncode
+    return rc == 0
+
+
+@task(name="record_singles", tags=["retro"])
+def record_singles(
+    singles: list[dict[str, Any]], target_pack: str, dry_run: bool
+) -> list[str]:
+    logger = get_run_logger()
+    recorded: list[str] = []
+    for s in singles:
+        note = s.get("note") or ""
+        if not note:
+            continue
+        text = f"[{target_pack}] {note}"
+        if dry_run:
+            recorded.append(text)
+            continue
+        if _bd_remember(text):
+            recorded.append(text)
+        else:
+            logger.warning(f"bd remember failed for: {text!r}")
+    return recorded
+
+
+@task(name="write_summary", tags=["retro"])
+def write_summary(
+    run_dir: str,
+    target_pack: str,
+    since: str,
+    n_runs: int,
+    recurring: list[dict[str, Any]],
+    singles_recorded: list[str],
+    commit: dict[str, Any],
+    timestamp: str,
+) -> str:
+    run_dir_p = Path(run_dir)
+    run_dir_p.mkdir(parents=True, exist_ok=True)
+    summary_path = run_dir_p / f"retro-{timestamp}.md"
+    lines: list[str] = [
+        f"# Retro for `{target_pack}` — {timestamp}",
+        "",
+        f"- Runs scanned: **{n_runs}** (since={since})",
+        f"- Recurring themes: **{len(recurring)}**",
+        f"- Single-occurrence notes: **{len(singles_recorded)}**",
+        f"- Branch: `{commit.get('branch') or '(none)'}`",
+        f"- Commit: `{commit.get('commit_sha') or '(none)'}`",
+        f"- Edited files: {commit.get('edited_files') or []}",
+    ]
+    if commit.get("skipped_reason"):
+        lines.append(f"- Skipped because: {commit['skipped_reason']}")
+    lines.append("")
+    if recurring:
+        lines.append("## Recurring themes")
+        lines.append("")
+        for r in recurring:
+            lines.append(
+                f"- **{r.get('theme', '(no theme)')}** → `{r.get('target_file')}`"
+            )
+            lines.append(
+                f"  evidence: {r.get('evidence', [])}"
+            )
+        lines.append("")
+    if singles_recorded:
+        lines.append("## Single-occurrence (recorded via `bd remember`)")
+        lines.append("")
+        for note in singles_recorded:
+            lines.append(f"- {note}")
+        lines.append("")
+    summary_path.write_text("\n".join(lines))
+    return str(summary_path)
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Flow
+# ──────────────────────────────────────────────────────────────────────
+
+
+@flow(name=_FORMULA_NAME)
+def update_prompts_from_lessons(
+    target_pack: str,
+    since: str = "7d",
+    rig_path: str | None = None,
+    dry_run: bool = False,
+) -> dict[str, Any]:
+    """Synthesize recurring lessons from the target pack's recent runs and
+    commit prompt/skill/CLAUDE.md edits to its repo.
+
+    Args:
+        target_pack: Distribution name of an editable PO formula pack.
+        since: How far back to scan run dirs (e.g. "7d", "24h").
+        rig_path: Rig root whose `.planning/<formula>/<issue>/` dirs
+            host run artifacts. Defaults to `$PWD`.
+        dry_run: If true, write the summary but do not edit files,
+            commit, or call `bd remember`.
+
+    Returns:
+        Dict with `refused` (when target pack is non-editable) OR
+        `summary_path`, `commit`, `n_runs`, `recurring`, `singles_recorded`.
+    """
+    rig = Path(rig_path or Path.cwd()).resolve()
+    timestamp = _utc_timestamp()
+    flow_run_dir = rig / ".planning" / _RUN_DIR_FORMULA / timestamp
+    flow_run_dir.mkdir(parents=True, exist_ok=True)
+
+    located = locate_target_pack(target_pack)
+    if "refused" in located:
+        return {"refused": located["refused"], "run_dir": str(flow_run_dir)}
+
+    repo_root = located["repo_root"]
+    formulas = located["formulas"]
+    runs = collect_lessons(str(rig), formulas, since)
+    synth = synthesize(target_pack, repo_root, runs, str(flow_run_dir))
+
+    commit = apply_changes_and_commit(
+        repo_root=repo_root,
+        target_pack=target_pack,
+        recurring=synth["recurring"],
+        n_runs=len(runs),
+        since=since,
+        timestamp=timestamp,
+        dry_run=dry_run,
+    )
+    singles_recorded = record_singles(synth["single_occurrence"], target_pack, dry_run)
+    summary_path = write_summary(
+        run_dir=str(flow_run_dir),
+        target_pack=target_pack,
+        since=since,
+        n_runs=len(runs),
+        recurring=synth["recurring"],
+        singles_recorded=singles_recorded,
+        commit=commit,
+        timestamp=timestamp,
+    )
+    return {
+        "summary_path": summary_path,
+        "commit": commit,
+        "n_runs": len(runs),
+        "recurring": synth["recurring"],
+        "singles_recorded": singles_recorded,
+        "run_dir": str(flow_run_dir),
+    }
