@@ -0,0 +1,260 @@
+"""Unit tests for `po_formulas_retro.analysis`."""
+
+from __future__ import annotations
+
+import json
+import os
+import time
+from datetime import datetime, timedelta, timezone
+from pathlib import Path
+
+import pytest
+
+from po_formulas_retro import analysis
+
+
+# ──────────────────────────────────────────────────────────────────────
+# parse_since
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_parse_since_supports_all_units() -> None:
+    assert analysis.parse_since("30s") == timedelta(seconds=30)
+    assert analysis.parse_since("15m") == timedelta(minutes=15)
+    assert analysis.parse_since("24h") == timedelta(hours=24)
+    assert analysis.parse_since("7d") == timedelta(days=7)
+    assert analysis.parse_since("2w") == timedelta(weeks=2)
+
+
+def test_parse_since_rejects_garbage() -> None:
+    with pytest.raises(ValueError):
+        analysis.parse_since("yesterday")
+    with pytest.raises(ValueError):
+        analysis.parse_since("7")
+
+
+# ──────────────────────────────────────────────────────────────────────
+# is_allowed_target_path
+# ──────────────────────────────────────────────────────────────────────
+
+
+@pytest.mark.parametrize(
+    "rel,allowed",
+    [
+        ("agents/builder/prompt.md", True),
+        ("po_formulas/agents/builder/prompt.md", True),
+        ("skills/retro/SKILL.md", True),
+        ("CLAUDE.md", True),
+        ("docs/CLAUDE.md", True),
+        ("po_formulas/builder.py", False),
+        ("pyproject.toml", False),
+        ("tests/test_x.py", False),
+        ("../etc/passwd", False),
+        ("/etc/passwd", False),
+        ("agents/builder/notes.md", False),
+    ],
+)
+def test_is_allowed_target_path(rel: str, allowed: bool) -> None:
+    assert analysis.is_allowed_target_path(rel) is allowed
+
+
+# ──────────────────────────────────────────────────────────────────────
+# filter_recurring
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_filter_recurring_drops_below_threshold() -> None:
+    items = [
+        {
+            "theme": "use scoped git add",
+            "evidence": ["a", "b"],  # only 2 — drop
+            "target_file": "agents/builder/prompt.md",
+            "edit": {"append": "x"},
+        },
+        {
+            "theme": "always read CLAUDE.md first",
+            "evidence": ["a", "b", "c"],
+            "target_file": "agents/builder/prompt.md",
+            "edit": {"append": "y"},
+        },
+    ]
+    out = analysis.filter_recurring(items)
+    assert len(out) == 1
+    assert out[0]["theme"] == "always read CLAUDE.md first"
+
+
+def test_filter_recurring_drops_disallowed_target() -> None:
+    items = [
+        {
+            "theme": "x",
+            "evidence": ["a", "b", "c", "d"],
+            "target_file": "po_formulas/builder.py",  # code — drop
+            "edit": "new contents",
+        }
+    ]
+    assert analysis.filter_recurring(items) == []
+
+
+def test_filter_recurring_dedupes_evidence() -> None:
+    items = [
+        {
+            "theme": "x",
+            "evidence": ["a", "a", "b"],  # only 2 distinct
+            "target_file": "agents/builder/prompt.md",
+            "edit": {"append": "x"},
+        }
+    ]
+    assert analysis.filter_recurring(items) == []
+
+
+# ──────────────────────────────────────────────────────────────────────
+# bucket_recurrences
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_bucket_recurrences_normalizes_whitespace_case_and_threshold() -> None:
+    snippets = [
+        ("run-1", "Always READ claude.md first"),
+        ("run-2", "always read CLAUDE.md  first"),
+        ("run-3", "  always read CLAUDE.md first  "),
+        ("run-4", "use scoped git add"),
+    ]
+    buckets = analysis.bucket_recurrences(snippets)
+    keys = list(buckets.keys())
+    assert len(keys) == 1
+    assert sorted(buckets[keys[0]]) == ["run-1", "run-2", "run-3"]
+
+
+# ──────────────────────────────────────────────────────────────────────
+# editable-install + repo-root resolution
+# ──────────────────────────────────────────────────────────────────────
+
+
+class _FakeDist:
+    def __init__(self, payload: dict | None) -> None:
+        self._payload = payload
+
+    def read_text(self, name: str) -> str | None:
+        if name == "direct_url.json" and self._payload is not None:
+            return json.dumps(self._payload)
+        return None
+
+
+def test_is_editable_install_true_when_dir_info_editable() -> None:
+    dist = _FakeDist({"url": "file:///tmp/pkg", "dir_info": {"editable": True}})
+    assert analysis.is_editable_install(dist) is True  # type: ignore[arg-type]
+
+
+def test_is_editable_install_false_when_missing() -> None:
+    assert analysis.is_editable_install(_FakeDist(None)) is False  # type: ignore[arg-type]
+
+
+def test_is_editable_install_false_when_dir_info_not_editable() -> None:
+    dist = _FakeDist({"url": "file:///tmp/pkg", "dir_info": {"editable": False}})
+    assert analysis.is_editable_install(dist) is False  # type: ignore[arg-type]
+
+
+def test_pack_repo_root_walks_to_git_ancestor(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
+) -> None:
+    repo = tmp_path / "fake-repo"
+    pkg = repo / "src" / "fake_pkg"
+    pkg.mkdir(parents=True)
+    (repo / ".git").mkdir()
+    payload = {"url": f"file://{pkg}", "dir_info": {"editable": True}}
+    monkeypatch.setattr(
+        analysis, "distribution", lambda name: _FakeDist(payload)
+    )
+    assert analysis.pack_repo_root("fake-pkg") == repo
+
+
+def test_pack_repo_root_refuses_non_editable(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
+) -> None:
+    pkg = tmp_path / "site-packages" / "fake_pkg"
+    pkg.mkdir(parents=True)
+    payload = {"url": f"file://{pkg}", "dir_info": {"editable": False}}
+    monkeypatch.setattr(
+        analysis, "distribution", lambda name: _FakeDist(payload)
+    )
+    with pytest.raises(LookupError, match="not an editable install"):
+        analysis.pack_repo_root("fake-pkg")
+
+
+def test_pack_repo_root_refuses_no_git_ancestor(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
+) -> None:
+    pkg = tmp_path / "weird" / "fake_pkg"
+    pkg.mkdir(parents=True)
+    payload = {"url": f"file://{pkg}", "dir_info": {"editable": True}}
+    monkeypatch.setattr(
+        analysis, "distribution", lambda name: _FakeDist(payload)
+    )
+    with pytest.raises(LookupError, match="no .git ancestor"):
+        analysis.pack_repo_root("fake-pkg")
+
+
+def test_pack_formula_names_reads_pyproject(tmp_path: Path) -> None:
+    (tmp_path / "pyproject.toml").write_text(
+        '[project]\nname = "x"\n\n'
+        '[project.entry-points."po.formulas"]\n'
+        'foo = "x.y:z"\n'
+        'bar = "x.y:w"\n'
+    )
+    names = analysis.pack_formula_names(tmp_path)
+    assert sorted(names) == ["bar", "foo"]
+
+
+def test_pack_formula_names_empty_when_no_pyproject(tmp_path: Path) -> None:
+    assert analysis.pack_formula_names(tmp_path) == []
+
+
+# ──────────────────────────────────────────────────────────────────────
+# iter_run_dirs
+# ──────────────────────────────────────────────────────────────────────
+
+
+def _touch(p: Path, mtime: float) -> None:
+    p.parent.mkdir(parents=True, exist_ok=True)
+    p.write_text("x")
+    os.utime(p, (mtime, mtime))
+
+
+def test_iter_run_dirs_filters_by_mtime(tmp_path: Path) -> None:
+    rig = tmp_path / "rig"
+    formula = "software-dev-full"
+    now = datetime.now(timezone.utc)
+    fresh_ts = (now - timedelta(days=2)).timestamp()
+    stale_ts = (now - timedelta(days=30)).timestamp()
+    _touch(rig / ".planning" / formula / "fresh-1" / "lessons-learned.md", fresh_ts)
+    _touch(rig / ".planning" / formula / "fresh-2" / "lessons-learned.md", fresh_ts)
+    _touch(rig / ".planning" / formula / "stale-1" / "lessons-learned.md", stale_ts)
+    out = list(
+        analysis.iter_run_dirs(rig, [formula], timedelta(days=7), now=now)
+    )
+    names = sorted(p.name for p in out)
+    assert names == ["fresh-1", "fresh-2"]
+
+
+def test_iter_run_dirs_falls_back_to_dir_mtime(tmp_path: Path) -> None:
+    rig = tmp_path / "rig"
+    formula = "software-dev-full"
+    now = datetime.now(timezone.utc)
+    fresh_ts = (now - timedelta(hours=1)).timestamp()
+    run_dir = rig / ".planning" / formula / "decisions-only"
+    run_dir.mkdir(parents=True)
+    _touch(run_dir / "decision-log.md", fresh_ts)
+    os.utime(run_dir, (fresh_ts, fresh_ts))
+    out = list(
+        analysis.iter_run_dirs(rig, [formula], timedelta(days=7), now=now)
+    )
+    assert [p.name for p in out] == ["decisions-only"]
+
+
+def test_read_lessons_and_decisions(tmp_path: Path) -> None:
+    rd = tmp_path / "rd"
+    rd.mkdir()
+    (rd / "lessons-learned.md").write_text("L")
+    (rd / "decision-log.md").write_text("D")
+    out = analysis.read_lessons_and_decisions(rd)
+    assert out == {"lessons": "L", "decisions": "D"}
