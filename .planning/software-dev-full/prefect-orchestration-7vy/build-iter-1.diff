@@ -0,0 +1,72 @@
+"""Tiny git wrapper used by the retro flow.
+
+Keeps git invocations contained so tests can monkey-patch one helper
+rather than every subprocess call. Uses `core.hooksPath=/dev/null` for
+commits so a target repo's pre-commit hook can't auto-push the retro
+commit.
+"""
+
+from __future__ import annotations
+
+import subprocess
+from pathlib import Path
+
+
+def _run(cmd: list[str], cwd: Path) -> str:
+    result = subprocess.run(
+        cmd, cwd=str(cwd), check=True, text=True, capture_output=True
+    )
+    return result.stdout.strip()
+
+
+def current_branch(repo: Path) -> str:
+    return _run(["git", "rev-parse", "--abbrev-ref", "HEAD"], repo)
+
+
+def branch_exists(repo: Path, name: str) -> bool:
+    rc = subprocess.run(
+        ["git", "rev-parse", "--verify", "--quiet", f"refs/heads/{name}"],
+        cwd=str(repo),
+        capture_output=True,
+    ).returncode
+    return rc == 0
+
+
+def ensure_retro_branch(repo: Path, timestamp: str) -> str | None:
+    """If on main/master, create+checkout `retro/<timestamp>` and return its name.
+
+    Otherwise return None (stay on the active feature branch).
+    Resolves naming collisions by appending `-1`, `-2`, ...
+    """
+    branch = current_branch(repo)
+    if branch not in ("main", "master"):
+        return None
+    base = f"retro/{timestamp}"
+    candidate = base
+    suffix = 1
+    while branch_exists(repo, candidate):
+        candidate = f"{base}-{suffix}"
+        suffix += 1
+    _run(["git", "checkout", "-b", candidate], repo)
+    return candidate
+
+
+def commit_paths(repo: Path, paths: list[Path], message: str) -> str:
+    """Scoped `git add <path>` then commit (hooks disabled). Returns commit SHA."""
+    if not paths:
+        raise ValueError("commit_paths requires at least one path")
+    for p in paths:
+        rel = p.relative_to(repo) if p.is_absolute() else p
+        _run(["git", "add", "--", str(rel)], repo)
+    _run(
+        [
+            "git",
+            "-c",
+            "core.hooksPath=/dev/null",
+            "commit",
+            "-m",
+            message,
+        ],
+        repo,
+    )
+    return _run(["git", "rev-parse", "HEAD"], repo)
