+"""Pure helpers for the retro formula.
+
+No Prefect, no Claude — just filesystem + metadata inspection so each
+helper can be unit-tested in isolation.
+"""
+
+from __future__ import annotations
+
+import json
+import re
+import sys
+import urllib.parse
+from collections.abc import Iterator
+from datetime import datetime, timedelta, timezone
+from importlib.metadata import Distribution, PackageNotFoundError, distribution
+from pathlib import Path
+
+if sys.version_info >= (3, 11):
+    import tomllib
+else:  # pragma: no cover - py3.11+ required by pyproject
+    import tomli as tomllib  # type: ignore[no-redef]
+
+
+# ──────────────────────────────────────────────────────────────────────
+# `since` parsing
+# ──────────────────────────────────────────────────────────────────────
+
+
+_SINCE_RE = re.compile(r"^\s*(\d+)\s*([smhdw])\s*$", re.IGNORECASE)
+_SINCE_UNITS = {
+    "s": 1,
+    "m": 60,
+    "h": 3600,
+    "d": 86400,
+    "w": 604800,
+}
+
+
+def parse_since(since: str) -> timedelta:
+    """Parse a 'Ns'/'Nm'/'Nh'/'Nd'/'Nw' shorthand into a timedelta.
+
+    Raises ValueError on malformed input.
+    """
+    m = _SINCE_RE.match(since)
+    if not m:
+        raise ValueError(
+            f"unrecognized 'since' value {since!r}; expected e.g. '7d', '24h', '30m'"
+        )
+    n, unit = int(m.group(1)), m.group(2).lower()
+    return timedelta(seconds=n * _SINCE_UNITS[unit])
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Editable-install detection + repo root resolution
+# ──────────────────────────────────────────────────────────────────────
+
+
+def _direct_url(dist: Distribution) -> dict | None:
+    """Return parsed `direct_url.json` payload or None if absent."""
+    try:
+        text = dist.read_text("direct_url.json")
+    except Exception:
+        return None
+    if not text:
+        return None
+    try:
+        return json.loads(text)
+    except json.JSONDecodeError:
+        return None
+
+
+def is_editable_install(dist: Distribution) -> bool:
+    """Heuristic editable-install test (PEP 660 + legacy)."""
+    payload = _direct_url(dist)
+    if payload is None:
+        return False
+    dir_info = payload.get("dir_info") or {}
+    return bool(dir_info.get("editable"))
+
+
+def _file_uri_to_path(url: str) -> Path | None:
+    """Convert a `file://` URL to a local Path; None for non-file URLs."""
+    if not url.startswith("file://"):
+        return None
+    parsed = urllib.parse.urlparse(url)
+    return Path(urllib.parse.unquote(parsed.path))
+
+
+def _walk_to_git_root(start: Path) -> Path | None:
+    """Walk parents of `start` until a `.git` dir is found, else None."""
+    for parent in [start, *start.parents]:
+        if (parent / ".git").exists():
+            return parent
+    return None
+
+
+def pack_repo_root(target_pack: str) -> Path:
+    """Resolve the on-disk git working-tree root for an installed pack.
+
+    Raises LookupError when the pack is not editable, when its
+    `direct_url.json` is missing/non-file, or when no `.git` ancestor
+    exists.
+    """
+    try:
+        dist = distribution(target_pack)
+    except PackageNotFoundError as exc:
+        raise LookupError(f"target_pack {target_pack!r} is not installed") from exc
+
+    if not is_editable_install(dist):
+        raise LookupError(
+            f"target_pack {target_pack!r} is not an editable install — refusing"
+        )
+
+    payload = _direct_url(dist) or {}
+    src = _file_uri_to_path(payload.get("url", ""))
+    if src is None or not src.exists():
+        raise LookupError(
+            f"target_pack {target_pack!r} direct_url is not a local file path"
+        )
+
+    root = _walk_to_git_root(src)
+    if root is None:
+        raise LookupError(
+            f"target_pack {target_pack!r} src {src} has no .git ancestor"
+        )
+    return root
+
+
+def pack_formula_names(repo_root: Path) -> list[str]:
+    """Read `[project.entry-points."po.formulas"]` keys from a pack's pyproject.toml."""
+    pyproject = repo_root / "pyproject.toml"
+    if not pyproject.exists():
+        return []
+    with pyproject.open("rb") as f:
+        data = tomllib.load(f)
+    eps = (
+        data.get("project", {})
+        .get("entry-points", {})
+        .get("po.formulas", {})
+    )
+    return list(eps.keys())
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Lesson collection
+# ──────────────────────────────────────────────────────────────────────
+
+
+def iter_run_dirs(
+    rig_path: Path,
+    formula_names: list[str],
+    since: timedelta,
+    *,
+    now: datetime | None = None,
+) -> Iterator[Path]:
+    """Yield run-dirs for the given formulas whose lessons-learned.md is recent enough.
+
+    A run dir is `<rig_path>/.planning/<formula>/<issue_id>/`. Filters
+    by `lessons-learned.md` mtime, falling back to the dir's own mtime
+    when the file is absent (so decision-log-only runs are still
+    surfaced).
+    """
+    cutoff = (now or datetime.now(timezone.utc)) - since
+    cutoff_ts = cutoff.timestamp()
+    planning_root = rig_path / ".planning"
+    for formula in formula_names:
+        formula_root = planning_root / formula
+        if not formula_root.is_dir():
+            continue
+        for run_dir in sorted(formula_root.iterdir()):
+            if not run_dir.is_dir():
+                continue
+            anchor = run_dir / "lessons-learned.md"
+            ref_path = anchor if anchor.exists() else run_dir
+            try:
+                mtime = ref_path.stat().st_mtime
+            except FileNotFoundError:
+                continue
+            if mtime >= cutoff_ts:
+                yield run_dir
+
+
+def read_lessons_and_decisions(run_dir: Path) -> dict[str, str]:
+    """Return {'lessons': ..., 'decisions': ...} for a single run dir."""
+    out: dict[str, str] = {}
+    lessons = run_dir / "lessons-learned.md"
+    if lessons.exists():
+        out["lessons"] = lessons.read_text(errors="replace")
+    decisions = run_dir / "decision-log.md"
+    if decisions.exists():
+        out["decisions"] = decisions.read_text(errors="replace")
+    return out
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Path safety
+# ──────────────────────────────────────────────────────────────────────
+
+
+_ALLOWED_PATTERNS = (
+    re.compile(r"(^|/)agents/.+/prompt\.md$"),
+    re.compile(r"(^|/)skills/.+/SKILL\.md$"),
+    re.compile(r"(^|/|\\)CLAUDE\.md$"),
+)
+
+
+def is_allowed_target_path(rel_path: str) -> bool:
+    """Allow only prompts, skills, and CLAUDE.md edits."""
+    if ".." in Path(rel_path).parts:
+        return False
+    if Path(rel_path).is_absolute():
+        return False
+    return any(p.search(rel_path) for p in _ALLOWED_PATTERNS)
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Synthesizer-output validation
+# ──────────────────────────────────────────────────────────────────────
+
+
+RECURRENCE_THRESHOLD = 3
+
+
+def filter_recurring(items: list[dict]) -> list[dict]:
+    """Drop items whose evidence list has < RECURRENCE_THRESHOLD distinct run_ids
+    or whose target_file isn't an allowed path. Preserves order otherwise.
+    """
+    out: list[dict] = []
+    for item in items:
+        evidence = item.get("evidence") or []
+        if not isinstance(evidence, list):
+            continue
+        distinct = {str(e) for e in evidence if e}
+        if len(distinct) < RECURRENCE_THRESHOLD:
+            continue
+        target = item.get("target_file") or ""
+        if not is_allowed_target_path(target):
+            continue
+        out.append(item)
+    return out
+
+
+def bucket_recurrences(snippets: list[tuple[str, str]]) -> dict[str, list[str]]:
+    """Group `(run_id, snippet)` pairs by trimmed snippet text.
+
+    Pure helper for offline analysis / tests — not used in the synth
+    flow, but documented in the plan as the "recurring patterns" check.
+    """
+    buckets: dict[str, set[str]] = {}
+    for run_id, snippet in snippets:
+        key = " ".join(snippet.split()).strip().lower()
+        if not key:
+            continue
+        buckets.setdefault(key, set()).add(run_id)
+    return {k: sorted(v) for k, v in buckets.items() if len(v) >= RECURRENCE_THRESHOLD}
