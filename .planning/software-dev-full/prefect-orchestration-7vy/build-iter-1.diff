new file mode 100644
index 0000000..fd5bc02
--- /dev/null
+++ b/tests/test_flow.py
@@ -0,0 +1,263 @@
+"""Integration tests for `update_prompts_from_lessons`.
+
+Uses a fake target-pack git repo + a fake rig with three matching
+lesson runs. The synthesizer turn is replaced with a fake backend
+that writes a canned verdict payload to the verdict file the prompt
+contains. No real Claude calls.
+"""
+
+from __future__ import annotations
+
+import json
+import re
+import subprocess
+import uuid
+from pathlib import Path
+from typing import Any
+
+import pytest
+
+pytest.importorskip("prefect")
+
+from po_formulas_retro import analysis, flows
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Fake backend
+# ──────────────────────────────────────────────────────────────────────
+
+
+class _CannedBackend:
+    """Mimics StubBackend but writes a caller-supplied payload."""
+
+    def __init__(self, payload: dict) -> None:
+        self.payload = payload
+        self.invocations: list[str] = []
+
+    def run(
+        self,
+        prompt: str,
+        *,
+        session_id: str | None,
+        cwd: Path,
+        fork: bool = False,
+        model: str = "opus",
+    ) -> tuple[str, str]:
+        self.invocations.append(prompt)
+        match = re.search(r"(/[^\s`]+/verdicts/[\w\-.]+\.json)", prompt)
+        assert match is not None, "prompt missing verdict path"
+        verdict_path = Path(match.group(1))
+        verdict_path.parent.mkdir(parents=True, exist_ok=True)
+        verdict_path.write_text(json.dumps(self.payload))
+        return "[fake] ack", session_id or f"fake-{uuid.uuid4().hex[:8]}"
+
+
+def _patch_target_pack(
+    monkeypatch: pytest.MonkeyPatch, target_pack: str, repo_root: Path
+) -> None:
+    """Make `analysis.pack_repo_root(target_pack)` return `repo_root`."""
+
+    def fake_pack_repo_root(name: str) -> Path:
+        assert name == target_pack
+        return repo_root
+
+    monkeypatch.setattr(analysis, "pack_repo_root", fake_pack_repo_root)
+    monkeypatch.setattr(flows.analysis, "pack_repo_root", fake_pack_repo_root)
+
+
+def _patch_backend(
+    monkeypatch: pytest.MonkeyPatch, backend: _CannedBackend
+) -> None:
+    monkeypatch.setattr(flows, "_select_backend", lambda: backend)
+
+
+def _patch_bd_remember(monkeypatch: pytest.MonkeyPatch) -> list[str]:
+    """Capture bd remember calls into a list rather than shelling out."""
+    captured: list[str] = []
+
+    def fake(text: str) -> bool:
+        captured.append(text)
+        return True
+
+    monkeypatch.setattr(flows, "_bd_remember", fake)
+    return captured
+
+
+def _git(repo: Path, *args: str) -> str:
+    return subprocess.run(
+        ["git", *args],
+        cwd=str(repo),
+        check=True,
+        text=True,
+        capture_output=True,
+    ).stdout.strip()
+
+
+# ──────────────────────────────────────────────────────────────────────
+# AC #2 + #9: flow detects pattern, proposes prompt edit, commits scoped
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_three_matching_runs_produce_prompt_edit(
+    fake_target_repo: Path,
+    fake_rig_with_runs: Path,
+    stub_synthesis_payload: dict,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    target_pack = "po-formulas-fake"
+    _patch_target_pack(monkeypatch, target_pack, fake_target_repo)
+    backend = _CannedBackend(stub_synthesis_payload)
+    _patch_backend(monkeypatch, backend)
+    bd_calls = _patch_bd_remember(monkeypatch)
+
+    result = flows.update_prompts_from_lessons(
+        target_pack=target_pack,
+        since="7d",
+        rig_path=str(fake_rig_with_runs),
+    )
+
+    # AC #2: synthesizer was invoked exactly once and produced a verdict.
+    assert len(backend.invocations) == 1
+    # AC #9: a recurring theme was kept (and the disallowed singletons routed elsewhere).
+    assert len(result["recurring"]) == 1
+    assert result["recurring"][0]["target_file"].endswith("prompt.md")
+    # AC #4: single-occurrence lessons → bd remember (with [<pack>] prefix).
+    assert bd_calls == [f"[{target_pack}] scoped git add avoids worker collisions"]
+
+    commit = result["commit"]
+    assert commit["commit_sha"] is not None
+    assert commit["edited_files"] == [
+        "po_formulas_fake/agents/builder/prompt.md"
+    ]
+
+    # Commit landed and prompt was actually mutated.
+    edited = fake_target_repo / "po_formulas_fake/agents/builder/prompt.md"
+    assert "Run `bd prime` after a session reset" in edited.read_text()
+    show = _git(
+        fake_target_repo, "show", "--stat", "--format=%s", commit["commit_sha"]
+    )
+    assert f"retro({target_pack}): integrate lessons from 3 runs since 7d" in show
+    assert "po_formulas_fake/agents/builder/prompt.md" in show
+
+    # AC #5: summary artifact exists.
+    summary = Path(result["summary_path"])
+    assert summary.exists()
+    text = summary.read_text()
+    assert "Run `bd prime`" in text
+    assert commit["commit_sha"] in text
+
+
+# ──────────────────────────────────────────────────────────────────────
+# AC #3: branching policy
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_main_branch_creates_retro_branch(
+    fake_target_repo: Path,
+    fake_rig_with_runs: Path,
+    stub_synthesis_payload: dict,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    _patch_target_pack(monkeypatch, "po-formulas-fake", fake_target_repo)
+    _patch_backend(monkeypatch, _CannedBackend(stub_synthesis_payload))
+    _patch_bd_remember(monkeypatch)
+
+    result = flows.update_prompts_from_lessons(
+        target_pack="po-formulas-fake",
+        since="7d",
+        rig_path=str(fake_rig_with_runs),
+    )
+    branch = result["commit"]["branch"]
+    assert branch is not None
+    assert re.match(r"^retro/\d{8}T\d{6}Z(-\d+)?$", branch), branch
+    assert result["commit"]["branch_created"] is True
+    assert _git(fake_target_repo, "rev-parse", "--abbrev-ref", "HEAD") == branch
+
+
+def test_feature_branch_commits_in_place(
+    fake_target_repo: Path,
+    fake_rig_with_runs: Path,
+    stub_synthesis_payload: dict,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    _git(fake_target_repo, "checkout", "-b", "feat/something")
+    _patch_target_pack(monkeypatch, "po-formulas-fake", fake_target_repo)
+    _patch_backend(monkeypatch, _CannedBackend(stub_synthesis_payload))
+    _patch_bd_remember(monkeypatch)
+
+    result = flows.update_prompts_from_lessons(
+        target_pack="po-formulas-fake",
+        since="7d",
+        rig_path=str(fake_rig_with_runs),
+    )
+    assert result["commit"]["branch"] == "feat/something"
+    assert result["commit"]["branch_created"] is False
+    assert (
+        _git(fake_target_repo, "rev-parse", "--abbrev-ref", "HEAD")
+        == "feat/something"
+    )
+
+
+# ──────────────────────────────────────────────────────────────────────
+# AC #6: refusal on non-editable target pack
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_refuses_on_non_editable_target(
+    tmp_path: Path,
+    fake_rig_with_runs: Path,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    bd_calls = _patch_bd_remember(monkeypatch)
+
+    def fake_pack_repo_root(name: str) -> Path:
+        raise LookupError(f"target_pack {name!r} is not an editable install")
+
+    monkeypatch.setattr(analysis, "pack_repo_root", fake_pack_repo_root)
+    monkeypatch.setattr(flows.analysis, "pack_repo_root", fake_pack_repo_root)
+
+    # Backend should NEVER be called — make it explode if it is.
+    def explode() -> Any:
+        raise AssertionError("backend should not be selected on refusal path")
+
+    monkeypatch.setattr(flows, "_select_backend", explode)
+
+    result = flows.update_prompts_from_lessons(
+        target_pack="not-editable",
+        since="7d",
+        rig_path=str(fake_rig_with_runs),
+    )
+    assert "refused" in result
+    assert bd_calls == []
+
+
+# ──────────────────────────────────────────────────────────────────────
+# Dry-run path
+# ──────────────────────────────────────────────────────────────────────
+
+
+def test_dry_run_skips_commit_and_bd_remember(
+    fake_target_repo: Path,
+    fake_rig_with_runs: Path,
+    stub_synthesis_payload: dict,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    _patch_target_pack(monkeypatch, "po-formulas-fake", fake_target_repo)
+    _patch_backend(monkeypatch, _CannedBackend(stub_synthesis_payload))
+    bd_calls = _patch_bd_remember(monkeypatch)
+
+    pre_sha = _git(fake_target_repo, "rev-parse", "HEAD")
+    result = flows.update_prompts_from_lessons(
+        target_pack="po-formulas-fake",
+        since="7d",
+        rig_path=str(fake_rig_with_runs),
+        dry_run=True,
+    )
+    post_sha = _git(fake_target_repo, "rev-parse", "HEAD")
+    assert pre_sha == post_sha
+    assert result["commit"]["commit_sha"] is None
+    assert result["commit"]["skipped_reason"] == "dry-run"
+    # bd_remember not invoked (dry_run still records to summary text only).
+    assert bd_calls == []
+    summary = Path(result["summary_path"])
+    assert summary.exists()
