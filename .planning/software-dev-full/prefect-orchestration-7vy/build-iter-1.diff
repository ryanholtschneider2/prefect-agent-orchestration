+"""Prefect deployments for the retro formula pack.
+
+Discovered by core's `po deploy` via the `po.deployments` entry-point
+group. Pure construction — no I/O. The single `retro-weekly` deployment
+fires every Sunday at 09:00 UTC. Callers MUST supply `target_pack` and
+`rig_path` parameters at run time (parameters left empty here so the
+deployment is reusable across rigs).
+"""
+
+from __future__ import annotations
+
+from typing import Any
+
+from prefect.client.schemas.schedules import CronSchedule
+
+from .flows import update_prompts_from_lessons
+
+
+def register() -> list[Any]:
+    return [
+        update_prompts_from_lessons.to_deployment(
+            name="retro-weekly",
+            schedules=[CronSchedule(cron="0 9 * * 0", timezone="UTC")],
+            work_pool_name="po",
+            tags=["retro"],
+            description=(
+                "Weekly retrospective: synthesize lessons + decisions from "
+                "recent runs of `target_pack` into prompt/skill/CLAUDE.md "
+                "edits committed to the target pack's repo."
+            ),
+            parameters={"since": "7d"},
+        )
+    ]
