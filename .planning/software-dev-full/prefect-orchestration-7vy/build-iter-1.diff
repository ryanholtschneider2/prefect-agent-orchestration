+"""Test that the pack registers exactly one weekly cron deployment."""
+
+from __future__ import annotations
+
+import pytest
+
+pytest.importorskip("prefect")
+
+from po_formulas_retro.deployments import register
+
+
+def test_register_returns_one_weekly_deployment() -> None:
+    deployments = register()
+    assert len(deployments) == 1
+    d = deployments[0]
+    assert d.name == "retro-weekly"
+    assert d.work_pool_name == "po"
+    # Prefect 3 RunnerDeployment uses `.schedules` (list).
+    schedules = getattr(d, "schedules", None) or []
+    assert len(schedules) == 1
+    cron = getattr(schedules[0], "schedule", schedules[0])
+    cron_expr = getattr(cron, "cron", None) or getattr(
+        getattr(cron, "schedule", None), "cron", None
+    )
+    assert cron_expr == "0 9 * * 0"
