{
  "name": "@nanocorps/po-tui",
  "version": "0.1.0",
  "private": true,
  "description": "Live TUI dashboard for the po Prefect-orchestration swarm",
  "type": "module",
  "bin": {
    "po-tui": "dist/po-tui"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build --compile --target=bun-linux-x64 src/cli.tsx --outfile dist/po-tui",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "bun-types": "latest",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
