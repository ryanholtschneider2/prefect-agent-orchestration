{
  "name": "@nanocorps/po-tui",
  "version": "0.1.0",
  "private": true,
  "description": "Epic-first operations console for PO",
  "type": "module",
  "bin": {
    "po-tui": "dist/po-tui"
  },
  "scripts": {
    "dev": "bun run tui-next/src/cli.tsx",
    "build": "bun build --compile --target=bun-linux-x64 tui-next/src/cli.tsx --outfile dist/po-tui",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "ink-testing-library": "^4.0.0",
    "string-width": "^7.2.0",
    "bun-types": "latest",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
