__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.venv/
build/
dist/
*.egg-info/

# PO run artifacts (per-issue, regenerable)
.planning/software-dev-full/*/verdicts/
.planning/software-dev-full/*/*.log
.planning/software-dev-full/*/*.diff
.planning/software-dev-full/*/*.patch
.planning/software-dev-full/*/review-artifacts/
.planning/software-dev-full/*/final-tests.txt
.planning/software-dev-full/*/smoke-test-output.txt

# Worker-image Claude context (populated by scripts/sync-claude-context.sh).
# Generated locally from $HOME/.claude; never commit — leaks user config.
claude-context/*
!claude-context/.gitkeep
