__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.venv/
build/
dist/
*.egg-info/

# PO run artifacts — per-issue, regenerable from `po retry`.
# Whole tree is host-state; only the structure (planning/) ships.
.planning/

# bd local state (per-rig, generated by `bd init`):
#   - dolt sql-server data + lockfiles
#   - rig-specific identifiers
.beads/dolt/
.beads/embeddeddolt/
.beads/embeddeddolt.bak-*/
.beads/dolt-server.*
.beads/daemon-state.json
.beads/metadata.json

# Local PO state.
.po-cache/
.po-claude-spawn.lock
.smoke/
.tmux/
.claude/.settings.lock
.claude/scheduled_tasks.lock
.claude/planning/
.claude/skills/

# Worker-image Claude context (populated by scripts/sync-claude-context.sh).
# Generated locally from $HOME/.claude; never commit — leaks user config.
claude-context/*
!claude-context/.gitkeep

# Misc.
.firecrawl/
nohup.out

# Compiled TUI binary (99MB). Built via `cd tui && bun build --compile`.
# tui/.gitignore already excludes tui/{node_modules,dist}; this covers the
# convenience copy at bin/po-tui after `make tui-install`.
bin/po-tui
.beads/dolt/
.beads/dolt-server.log
.beads/dolt-server.pid
.beads/embeddeddolt/
.beads/embeddeddolt.bak*/
.beads/embeddeddolt.preserved-postmigration-*/
packs/*
!packs/README.md
!packs/po-formulas-examples/
!packs/po-formulas-examples/**
